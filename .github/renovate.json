{
  "extends": [
    "config:best-practices"
  ],

  "enabledManagers": [
    "argocd",
    "helm-values",
    "helmv3",
    "kustomize",
    "dockerfile",
    "docker-compose",
    "github-actions"
  ],

  "packageRules": [
    {
      "matchPackageNames": [
        "longhorn",
        "cert-manager",
        "kube-prometheus-stack",
        "argo-cd",
        "external-secrets",
        "trivy-operator"
      ],
      "automerge": false
    },
    {
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true
    }
  ]
}